{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiops-platform.local/schemas/feedback.schema.json",
  "title": "DeploymentFeedback",
  "type": "object",
  "required": [
    "schema_version",
    "deployment_id",
    "service",
    "risk_level",
    "recommended_actions"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "deployment_id": { "type": "string", "minLength": 1 },
    "service": { "type": "string", "minLength": 1 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "health_deltas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "anomaly_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "execution_mode"],
        "properties": {
          "action": { "type": "string" },
          "execution_mode": {
            "type": "string",
            "enum": ["auto_allowed", "approval_required"]
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
